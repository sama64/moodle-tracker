# Copy this file to .env and fill in your Moodle credentials.
APP_ENV=development
LOG_LEVEL=INFO
DATABASE_URL=postgresql+psycopg://uni_tracker:uni_tracker@db:5432/uni_tracker
RAW_STORAGE_PATH=/app/artifacts/runtime
SYNC_COURSES_INTERVAL_MINUTES=30
SYNC_CONTENTS_INTERVAL_MINUTES=60
FILE_DOWNLOAD_LIMIT_PER_RUN=5
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DAILY_DIGEST_HOUR=7
STALE_SYNC_THRESHOLD_HOURS=6
ENABLE_LLM=false
LLM_BODY_CHAR_LIMIT=12000
NVIDIA_API_KEY=
NVIDIA_API_URL=https://integrate.api.nvidia.com/v1/chat/completions
NVIDIA_MODEL=moonshotai/kimi-k2.5
MOODLE_BASE_URL=https://moodle.ingenieria.unlz.edu.ar
MOODLE_USERNAME=
MOODLE_PASSWORD=
MOODLE_SERVICE=moodle_mobile_app
